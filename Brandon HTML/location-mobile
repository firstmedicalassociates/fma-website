<script>
    const sheet = document.getElementById('bottom-sheet');
    const handle = document.getElementById('sheet-handle');
    
    // Toggle full height on click of the handle or header area
    handle.addEventListener('click', (e) => {
        if (sheet.classList.contains('sheet-collapsed')) {
            sheet.classList.remove('sheet-collapsed');
            sheet.classList.add('sheet-expanded');
        } else {
            sheet.classList.remove('sheet-expanded');
            sheet.classList.add('sheet-collapsed');
        }
    });

    // Expand if user scrolls up the content
    sheet.addEventListener('scroll', (e) => {
        if (sheet.classList.contains('sheet-collapsed') && sheet.scrollTop > 10) {
            sheet.classList.remove('sheet-collapsed');
            sheet.classList.add('sheet-expanded');
        }
    }, true);
</script>
