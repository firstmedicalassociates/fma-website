generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash later
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  metaTitle     String?
  metaDescription String?
  slug          String    @unique
  excerpt       String?
  contentHtml   String
  coverImageUrl String?
  coverImageAlt String?
  status        String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt   DateTime?
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  @@index([status, publishedAt])
}

model Provider {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  title     String
  bio       String
  imageUrl  String
  imageAlt  String?
  linkUrl   String?
  locations String[] @default([])
  languages String[] @default([])
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([isActive, sortOrder, name])
}

model Service {
  id          String   @id @default(cuid())
  category    String   @default("General Care")
  title       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder, title])
  @@index([category, sortOrder, title])
}

model Location {
  id                 String   @id @default(cuid())
  slug               String   @unique
  title              String
  eyebrow            String?
  accent             String?
  intro              String?
  address            String
  streetAddress      String?
  addressCity        String?
  addressState       String?
  postalCode         String?
  addressCountry     String?
  displayAddress     String?
  phone              String?
  directPhone        String?
  callTextPhone      String?
  hideOfficePhone    Boolean  @default(false)
  directionsUrl      String?
  bookingUrl         String?
  reviewUrl          String?
  mapImageUrl        String?
  mapImageAlt        String?
  parkingTitle       String?
  parkingDescription String?
  officeHours        Json     @default("[]")
  serviceIds         String[] @default([])
  services           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([updatedAt])
}
